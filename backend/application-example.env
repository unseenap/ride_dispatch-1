# Copy this file to `.env` (or export these as real environment variables) before running the backend.
# The values below are safe local-dev defaults only. NEVER commit real secrets.

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/dispatchhub
DB_USERNAME=dispatchhub
DB_PASSWORD=dispatchhub

# --- JWT ---
# Base64-encoded HMAC-SHA256 secret. Generate your own for anything beyond local dev, e.g.:
#   openssl rand -base64 64
JWT_SECRET=dGhpc2lzYXRlc3RzZWNyZXRrZXlmb3JkaXNwYXRjaGh1YmRldmVsb3BtZW50b25seQ==
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=dispatchhub-api

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Misc ---
SHOW_SQL=true
